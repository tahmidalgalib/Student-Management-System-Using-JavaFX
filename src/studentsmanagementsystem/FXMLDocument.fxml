<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="352.0" prefWidth="641.0" xmlns="http://javafx.com/javafx/1.8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studentsmanagementsystem.FXMLDocumentController">
   <children>
      <TableView fx:id="tvStudents" layoutX="218.0" layoutY="51.0" onMouseClicked="#onMouseClick" prefHeight="199.0" prefWidth="420.0">
        <columns>
          <TableColumn fx:id="colID" prefWidth="54.0" text="ID" />
          <TableColumn fx:id="colName" prefWidth="109.0" text="Name" />
            <TableColumn fx:id="colDept" prefWidth="72.0" text="Dept" />
            <TableColumn fx:id="colAge" prefWidth="45.0" text="Age" />
            <TableColumn fx:id="colEmail" prefWidth="138.0" text="Email" />
        </columns>
      </TableView>
      <VBox layoutX="14.0" layoutY="53.0" prefHeight="181.0" prefWidth="57.0" spacing="28.0">
         <children>
            <Label text="ID">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Label>
            <Label layoutX="10.0" layoutY="10.0" prefHeight="11.0" prefWidth="34.0" text="Name">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label layoutX="10.0" layoutY="27.0" text="Dept.">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label layoutX="10.0" layoutY="44.0" text="Age">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
            <Label layoutX="10.0" layoutY="61.0" text="Email">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font></Label>
         </children>
      </VBox>
      <VBox layoutX="54.0" layoutY="54.0" prefHeight="199.0" prefWidth="151.0" spacing="18.0">
         <children>
            <TextField fx:id="tfID" prefHeight="10.0" prefWidth="124.0" promptText="Enter SID(4 Digit)" />
            <TextField fx:id="tfName" layoutX="10.0" layoutY="10.0" prefHeight="58.0" prefWidth="124.0" promptText="Enter Name" />
            <TextField fx:id="tfDept" layoutX="10.0" layoutY="63.0" prefHeight="25.0" prefWidth="103.0" promptText="Enter Dept." />
            <TextField fx:id="tfAge" layoutX="10.0" layoutY="116.0" promptText="Enter Age" />
            <TextField fx:id="tfEmail" layoutX="10.0" layoutY="169.0" prefHeight="15.0" prefWidth="124.0" promptText="Enter @gmail" />
         </children>
      </VBox>
      <Button fx:id="btnInsert" layoutX="9.0" layoutY="281.0" mnemonicParsing="false" onAction="#handleButtonAction" prefHeight="25.0" prefWidth="57.0" style="-fx-background-color: #2ECC71; -fx-background-radius: 6;" text="Insert">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
      <Button fx:id="btnUpdate" layoutX="76.0" layoutY="281.0" mnemonicParsing="false" onAction="#handleButtonAction" prefHeight="25.0" prefWidth="64.0" style="-fx-background-color: #3498DB ; -fx-background-radius: 6;;" text="Update">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
      <Button fx:id="btnDelete" layoutX="150.0" layoutY="281.0" mnemonicParsing="false" onAction="#handleButtonAction" pickOnBounds="false" prefHeight="25.0" prefWidth="57.0" style="-fx-background-color: #E74C3C ; -fx-background-radius: 6;;" text="Delete">
         <font>
            <Font name="System Bold" size="12.0" />
         </font></Button>
      <Label layoutX="223.0" layoutY="14.0" prefHeight="1.0" prefWidth="195.0" text="Student Management System" textAlignment="CENTER" underline="true">
         <font>
            <Font name="System Bold" size="14.0" />
         </font>
      </Label>
      <Label layoutX="513.0" layoutY="329.0" text="Developed by: Tahmid" textFill="#4e4e4e">
         <font>
            <Font name="Garamond" size="12.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
